{
  "name": "@service-levels/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "worker": "tsx src/worker.ts",
    "worker:dev": "tsx watch src/worker.ts",
    "build": "tsc -p tsconfig.json",
    "coverage": "c8 --check-coverage --branches 50 --functions 50 --lines 50 --statements 50 --reporter=text --reporter=lcov --reporter=json-summary node --import tsx --test test/*.test.ts",
    "test": "node --import tsx --test test/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/cookie": "^9.4.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/formbody": "^7.4.0",
    "@fastify/static": "^7.0.4",
    "@node-saml/node-saml": "^5.1.0",
    "@service-levels/shared": "file:../../packages/shared",
    "@types/nodemailer": "^8.0.0",
    "fastify": "^4.28.1",
    "ipaddr.js": "^2.2.0",
    "jsonwebtoken": "^9.0.2",
    "ldapts": "^7.4.0",
    "nodemailer": "^8.0.5",
    "openid-client": "^6.8.3",
    "pg": "^8.13.1",
    "prom-client": "^15.1.3",
    "undici": "^7.25.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.7.7",
    "@types/pg": "^8.11.10",
    "c8": "^10.1.3",
    "pg-mem": "^3.0.14",
    "typescript": "^5.6.3"
  }
}
